DATABASE_URL="postgresql://postgres:postgres@localhost:5432/salesnest?schema=public"
SESSION_SECRET="replace-with-64-plus-character-random-secret"
SESSION_COOKIE_NAME="salesnest_session"
SESSION_TTL_DAYS="14"
APP_URL="http://localhost:3000"
LEGACY_PROGRESS_IMPORT_MAX_BYTES="10485760"
LEGACY_EXCEL_IMPORT_ENABLED="false"
GOOGLE_CALENDAR_INTEGRATION_ENABLED="false"
GOOGLE_CALENDAR_WEBHOOK_ENABLED="false"
PUBLIC_SCHEDULING_ENABLED="true"
FORM_BUILDER_V2_ENABLED="true"
GOOGLE_CALENDAR_CLIENT_ID=""
GOOGLE_CALENDAR_CLIENT_SECRET=""
# Vercel example:
# GOOGLE_CALENDAR_REDIRECT_URI="https://your-project.vercel.app/api/integrations/google-calendar/callback"
GOOGLE_CALENDAR_REDIRECT_URI="http://localhost:3000/api/integrations/google-calendar/callback"
# Vercel example:
# GOOGLE_CALENDAR_WEBHOOK_URL="https://your-project.vercel.app/api/google-calendar/webhook"
GOOGLE_CALENDAR_WEBHOOK_URL="http://localhost:3000/api/google-calendar/webhook"
APP_ENCRYPTION_KEY="replace-with-production-secret"
APP_ENCRYPTION_KEY_VERSION="v1"
